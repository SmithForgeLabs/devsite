# ===========================================
# DevSite — Environment Variables Template
# ===========================================
# Copy this file to .env and fill in values
# NEVER commit .env to git

# ── Database ────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/devsite?schema=public"

# ── JWT Secrets ─────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="CHANGE_ME_AT_LEAST_64_CHARS_RANDOM_STRING"
JWT_REFRESH_SECRET="CHANGE_ME_DIFFERENT_RANDOM_STRING_AT_LEAST_64_CHARS"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ── App ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"

# ── Redis (optional) ─────────────────────────
REDIS_URL="redis://localhost:6379"

# ── File Storage ────────────────────────────
# STORAGE_PROVIDER= "postgres" | "s3"  (default: postgres)
STORAGE_PROVIDER="postgres"
UPLOAD_MAX_SIZE_MB="10"

# ── S3 (fill only if STORAGE_PROVIDER=s3) ───
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
